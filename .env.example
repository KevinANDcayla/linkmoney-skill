# LinkMoney 生产环境配置
# 复制此文件为 .env 并填写真实值

# 服务端口
LINKMONEY_PORT=8765

# API Key（逗号分隔多个）
LINKMONEY_API_KEYS=lm-demo-2026,lm-prod-xxxx

# SMTP 邮件配置
LINKMONEY_MAIL_ENABLED=false
LINKMONEY_SMTP_HOST=smtp.qq.com
LINKMONEY_SMTP_PORT=587
LINKMONEY_SMTP_USER=your-email@qq.com
LINKMONEY_SMTP_PASSWORD=your-smtp-code
LINKMONEY_SMTP_FROM=your-email@qq.com

# MCP 代理转发
LINKMONEY_MCP_PROXY_ENABLED=true
LINKMONEY_MCP_PROXY_TIMEOUT=8

# 缓存 TTL（秒）
LINKMONEY_CACHE_TTL=60

# RFQ 邮件覆写（演示期所有询盘通知发到这里，后续替换真实厂商邮箱）
LINKMONEY_RFQ_OVERRIDE_EMAIL=kevin@coze.email

# 翻译 API（可选，后续接入 DeepL）
LINKMONEY_TRANSLATION_API_KEY=

# 日志
LINKMONEY_LOG_LEVEL=INFO
LINKMONEY_LOG_FILE=logs/linkmoney.log